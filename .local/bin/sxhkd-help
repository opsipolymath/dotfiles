#!/bin/bash

awk '/^# --/ {if ( !($0 == "# -- General") ) print ""; print "<small>\t</small>",substr($0,3)," --"} \
	/^[a-z@]/ && last {if ( !(substr($0,1,1) ~ /[a-z]/) ) $0=substr($0,2); print "<small>",$0,"\t",last,"</small>"} {last=""} \
	/^#/{last=substr($0,3)}' ~/.config/sxhkd/sxhkdrc |
	column -L -t -s $'\t' |
	rofi -dmenu -i -markup-rows -no-show-icons -width 1000 -lines 15 -yoffset 40
